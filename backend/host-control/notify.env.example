# Set NOTIFY_ENABLED=1 after filling at least one real channel.
NOTIFY_ENABLED=0
NOTIFY_DRY_RUN=0
NOTIFY_CHANNELS=webhook
NOTIFY_TITLE_PREFIX=[Mortis Public Watch]

# Generic webhook
NOTIFY_WEBHOOK_URL=

# Telegram Bot API
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Feishu incoming bot webhook
FEISHU_WEBHOOK_URL=

# Email via Resend API
RESEND_API_KEY=
RESEND_TO_EMAIL=
RESEND_FROM_EMAIL=

# QQ Bot via OpenClaw stock qqbot plugin
QQBOT_APP_ID=
QQBOT_CLIENT_SECRET=
QQBOT_TARGET=
QQBOT_TARGET_MODE=latest_c2c
QQBOT_KNOWN_USERS_PATH=/home/ubuntu/.openclaw/qqbot/data/known-users.json
QQBOT_ACCOUNT=default
OPENCLAW_BIN=openclaw

# NapCat via personal QQ + OneBot HTTP
NAPCAT_API_URL=http://127.0.0.1:3600
NAPCAT_ACCESS_TOKEN=
NAPCAT_MESSAGE_MODE=private
NAPCAT_USER_ID=
NAPCAT_GROUP_ID=
